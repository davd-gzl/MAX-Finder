{
  "name": "max-finder",
  "version": "0.1.0",
  "private": true,
  "description": "FOSS, serverless finder for free MAX JEUNE / MAX SENIOR (ex-TGVmax) seats, built on SNCF Open Data.",
  "license": "MPL-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "fetch-data": "tsx scripts/fetch-data.ts",
    "verify": "node scripts/verify-render.mjs",
    "test:e2e": "node scripts/e2e.mjs",
    "screenshot": "node scripts/screenshot.mjs",
    "build:mobile": "tsc --noEmit && vite build --mode capacitor",
    "cap:sync": "npm run build:mobile && cap sync",
    "cap:copy": "npm run build:mobile && cap copy",
    "cap:add:android": "cap add android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@sparticuz/chromium": "^149.0.0",
    "@types/leaflet": "^1.9.12",
    "jsdom": "^25.0.1",
    "puppeteer-core": "^25.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
