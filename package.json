{
  "name": "foss-maxjeune",
  "version": "0.1.0",
  "private": true,
  "description": "FOSS, serverless finder for free MAX JEUNE / MAX SENIOR (ex-TGVmax) seats, built on SNCF Open Data.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "fetch-data": "tsx scripts/fetch-data.ts",
    "screenshot": "node scripts/screenshot.mjs"
  },
  "dependencies": {
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@sparticuz/chromium": "^149.0.0",
    "@types/leaflet": "^1.9.12",
    "jsdom": "^25.0.1",
    "puppeteer-core": "^25.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
